{
  "dashboard": {
    "title": "PGQT Metrics",
    "tags": ["pgqt", "postgresql", "sqlite"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{
          "expr": "rate(pgqt_requests_total[5m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 2,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{
          "expr": "pgqt_connections_active",
          "legendFormat": "connections",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "min": 0
          }
        }
      },
      {
        "id": 3,
        "title": "Query Latency (P95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
        "targets": [{
          "expr": "histogram_quantile(0.95, rate(pgqt_query_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 latency",
          "refId": "A"
        }],
        "yAxes": [
          {
            "label": "Duration",
            "unit": "s"
          }
        ]
      },
      {
        "id": 4,
        "title": "Query Types",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {"expr": "pgqt_queries_select_total", "legendFormat": "SELECT", "refId": "A"},
          {"expr": "pgqt_queries_insert_total", "legendFormat": "INSERT", "refId": "B"},
          {"expr": "pgqt_queries_update_total", "legendFormat": "UPDATE", "refId": "C"},
          {"expr": "pgqt_queries_delete_total", "legendFormat": "DELETE", "refId": "D"}
        ]
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [{
          "expr": "rate(pgqt_requests_failed_total[5m]) / rate(pgqt_requests_total[5m])",
          "legendFormat": "error rate",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        }
      }
    ]
  },
  "overwrite": true
}
